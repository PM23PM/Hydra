<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hydra Store - Acquista Decode</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }
        body {
            font-family: Arial, sans-serif;
            color: #f0f0f0;
            background: linear-gradient(rgba(0,0,0,0.75), rgba(0,0,0,0.75)), url('https://i.imgur.com/NdfNIiy.png') center/cover fixed no-repeat;
            min-height: 100vh;
            line-height: 1.7;
            overflow-x: hidden;
        }

        /* Header riutilizzato quasi identico */
        header {
            position: fixed;
            top: 18px;
            left: 50%;
            transform: translateX(-50%);
            width: 95%;
            max-width: 1300px;
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 30px;
            background: rgba(0, 0, 0, 0.55);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: 0 8px 30px rgba(0,0,0,0.6), inset 0 0 0 1px rgba(255,255,255,0.03);
        }

        .logo-and-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .logo img {
            height: 28px;
        }
        .company-name {
            font-size: 22px;
            font-weight: 800;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 3px;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 24px;
        }
        nav ul li a {
            color: #ccc;
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 600;
            text-transform: uppercase;
            transition: color 0.25s;
        }
        nav ul li a:hover,
        nav ul li a.active {
            color: #ff6f61;
        }

        .cart-btn {
            background: #ff6f61;
            color: white;
            padding: 8px 16px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.25s;
        }
        .cart-btn:hover {
            background: #e65b50;
            transform: translateY(-1px);
        }

        .hamburger { display: none; }

        /* Main content */
        main {
            padding-top: 140px;
            padding-bottom: 80px;
        }

        .store-hero {
            text-align: center;
            padding: 60px 20px 100px;
        }
        .store-hero h1 {
            font-size: 4.2rem;
            font-weight: 900;
            background: linear-gradient(135deg, #ffffff, #ffb199);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 20px;
            text-shadow: 0 5px 25px rgba(255,111,97,0.4);
        }
        .store-hero p {
            font-size: 1.4rem;
            max-width: 800px;
            margin: 0 auto 40px;
            color: #ddd;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 40px;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .product-card {
            background: rgba(0,0,0,0.55);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 12px 40px rgba(0,0,0,0.6);
            transition: all 0.35s cubic-bezier(0.23,1,0.32,1);
            position: relative;
        }

        .product-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 25px 60px rgba(0,0,0,0.8), 0 0 80px rgba(255,111,97,0.25);
        }

        .product-image {
            width: 100%;
            height: 320px;
            object-fit: cover;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .product-info {
            padding: 28px 24px;
            text-align: center;
        }

        .product-title {
            font-size: 1.9rem;
            margin-bottom: 12px;
            color: #fff;
        }

        .product-desc {
            font-size: 1.05rem;
            color: #ccc;
            margin-bottom: 20px;
            min-height: 80px;
        }

        .price {
            font-size: 2.1rem;
            font-weight: 800;
            color: #ff6f61;
            margin-bottom: 24px;
            display: block;
        }

        .add-to-cart {
            background: #ff6f61;
            color: white;
            border: none;
            padding: 14px 32px;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
            width: 100%;
        }

        .add-to-cart:hover {
            background: #e65b50;
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255,111,97,0.5);
        }

        .badges {
            position: absolute;
            top: 16px;
            left: 16px;
            display: flex;
            gap: 10px;
        }
        .badge {
            background: rgba(255,111,97,0.9);
            color: white;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            backdrop-filter: blur(4px);
        }

        /* Footer semplificato */
        footer {
            background: rgba(0,0,0,0.8);
            padding: 60px 20px 40px;
            text-align: center;
            border-top: 1px solid rgba(255,255,255,0.08);
        }
        footer a {
            color: #ff6f61;
            text-decoration: none;
            margin: 0 14px;
        }
        footer a:hover { text-decoration: underline; }

        @media (max-width: 900px) {
            header { padding: 12px 20px; top: 10px; }
            .hamburger { display: flex; flex-direction: column; gap: 5px; cursor: pointer; }
            nav ul { display: none; }
            .store-hero h1 { font-size: 3.2rem; }
        }
    </style>
</head>
<body>

<header>
    <div class="logo-and-brand">
        <div class="logo">
            <a href="https://example.com/hydra-home"><img src="https://i.imgur.com/3eG6kO3.png" alt="Hydra Logo"></a>
        </div>
        <div class="company-name">HYDRA</div>
    </div>

    <nav>
        <ul>
            <li><a href="https://example.com/hydra-home">Torna al sito</a></li>
            <li><a href="#negozio" class="active">Negozio</a></li>
            <li><a href="#">Supporto</a></li>
        </ul>
    </nav>

    <a href="#carrello" class="cart-btn">
        <i class="fas fa-shopping-cart"></i> Carrello (0)
    </a>

    <div class="hamburger">
        <span></span><span></span><span></span>
    </div>
</header>

<main>

    <section class="store-hero">
        <h1>Hydra Store</h1>
        <p>Acquista Decode e supporta lo sviluppo di giochi italiani che uniscono intrattenimento, storia e rompicapi.</p>
    </section>

    <section class="products" id="negozio">
        <div class="products-grid">

            <!-- Prodotto principale -->
            <div class="product-card">
                <div class="badges">
                    <span class="badge">Pre-ordine</span>
                    <span class="badge">Early Access 2026</span>
                </div>
                <img src="https://i.imgur.com/SsF3h7C.jpeg" alt="Decode" class="product-image">
                <div class="product-info">
                    <h2 class="product-title">Decode</h2>
                    <p class="product-desc">
                        FPS rompicapo ambientato in eventi storici reali.<br>
                        Decifra codici Cesare, binario, Vigenère e molti altri per sabotare il nemico.
                    </p>
                    <span class="price">€19,99</span>
                    <button class="add-to-cart">Aggiungi al carrello</button>
                </div>
            </div>

            <!-- Prodotto futuro / placeholder -->
            <div class="product-card" style="opacity:0.6; filter: grayscale(40%);">
                <div class="badges">
                    <span class="badge">In arrivo</span>
                </div>
                <img src="https://via.placeholder.com/400x320/111/eee?text=Prossimo+Titolo+2027" alt="Coming soon" class="product-image">
                <div class="product-info">
                    <h2 class="product-title">Progetto #2</h2>
                    <p class="product-desc">Annunci in arrivo nel 2026/2027.<br>Iscriviti alla newsletter per essere tra i primi a sapere.</p>
                    <span class="price">TBA</span>
                    <button class="add-to-cart" disabled>Non disponibile</button>
                </div>
            </div>

        </div>
    </section>

</main>

<footer>
    <p>© 2026 Hydra Gaming S.r.l. – P.IVA 23503618214</p>
    <p>
        <a href="https://example.com/hydra-home#termini">Termini e Condizioni</a> •
        <a href="https://example.com/hydra-home#privacy">Privacy</a> •
        <a href="https://example.com/hydra-home#cookie">Cookie</a>
    </p>
</footer>

<script>
// Solo un piccolo script dimostrativo per il bottone
document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', () => {
        if (!btn.disabled) {
            alert("Decode aggiunto al carrello! (demo)");
        }
    });
});
</script>
</body>
</html>
